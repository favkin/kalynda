VITE_API_URL=http://localhost:4040/api

# Your WhatsApp number in international format, digits only (no +, no spaces, no dashes).
# Example: for +234 801 234 5678, use 2348012345678
VITE_WHATSAPP_NUMBER=2348012345678

# Currency symbol shown next to prices. Defaults to ₦ if not set.
VITE_CURRENCY_SYMBOL=₦

# Optional — shown on the Contact page if set. Leave blank to omit.
VITE_CONTACT_EMAIL=hello@kalynda.com
VITE_INSTAGRAM_HANDLE=kalynda
